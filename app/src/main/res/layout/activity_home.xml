<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">



            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Šta kuhamo danas?"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>
        <TextView
            android:id="@+id/btnFavoritesHome"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="❤️"
            android:textSize="22sp"
            android:gravity="center"
            android:background="#16213E"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/btnShoppingHome"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="🛒"
            android:textSize="22sp"
            android:gravity="center"
            android:background="#16213E"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvProfileBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="👤"
            android:textSize="22sp"
            android:gravity="center"
            android:background="#16213E" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="🔍  Pretraži recepte..."

            android:textColor="#FFFFFF"
            android:background="#16213E"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true" />

    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="20dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/layoutCategories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical" />

    </HorizontalScrollView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Svi recepti"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingStart="20dp"
        android:paddingBottom="12dp" />


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerRecipes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false" />



</LinearLayout>